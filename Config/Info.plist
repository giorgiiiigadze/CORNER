<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Base Info.plist. Xcode merges its generated keys (usage descriptions,
	     orientations, scene manifest) on top of this at build time.

	     This exists solely because INFOPLIST_KEY_* build settings only support
	     Apple's own known keys - an arbitrary one is silently dropped. The value
	     below is substituted from Secrets.xcconfig, which is gitignored.

	     The key lands in the app bundle in plain text and can be extracted from
	     the .ipa. Fine on your own device; a ship-blocker for public TestFlight. -->
	<!-- The phone is across the room, screen off, in a bag or a pocket. Without
	     this, iOS suspends the app the moment it backgrounds and the workout
	     stops mid-round. `audio` keeps the session, the callouts and the
	     microphone alive with the screen locked. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- The session's Lock Screen card. Without this, Activity.request throws
	     and the timer exists only inside the app. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- The wordmark's face. Bundled rather than relying on a system font: the
	     header is the app's name and it should look the same on every phone.
	     The path is relative to the bundle root, and the name to *use* in code is
	     the PostScript name — "BebasNeue-Regular" — not this filename. -->
	<key>UIAppFonts</key>
	<array>
		<string>BebasNeue-Regular.ttf</string>
	</array>
	<!-- Apple Health. These live in the base plist rather than as
	     INFOPLIST_KEY_* build settings because the HealthKit usage keys aren't
	     on Xcode's whitelist of known keys - an arbitrary one is silently
	     dropped (the same reason the comment at the top of this file gives).

	     Read is what the profile screen uses: it pulls height, weight and date
	     of birth so the fighter doesn't retype what Health already knows.
	     Write is here for the near future - copying a finished session back to
	     Health as a workout - so turning it on is a code change, not another
	     round through the permission-string plumbing. -->
	<key>NSHealthShareUsageDescription</key>
	<string>So it can fill in your height, weight and date of birth from Apple Health instead of asking you to type them.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>So your finished sessions and any measurements you enter can be saved to Apple Health.</string>
</dict>
</plist>
